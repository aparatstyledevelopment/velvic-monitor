# Copy to .env.local for local development. .env.local is gitignored.

# Backend
ENV=local
ENGINE_VERSION=v0.1.0+dev
DATABASE_URL=postgresql+asyncpg://velvic:velvic@localhost:5432/velvic
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-32-byte-key-for-pgcrypto

CORS_ORIGINS=["http://localhost:5173"]

# LLM providers (optional locally; required for chat tests + evals)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# External data
FRED_API_KEY=

# Email (Postmark in production; local dev logs to console)
POSTMARK_TOKEN=

# Observability
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Frontend (only VITE_-prefixed vars are exposed to the SPA)
VITE_API_URL=http://localhost:8080
